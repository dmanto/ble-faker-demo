{
  "name": "ble-faker-demo",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "start:mock": "cross-env BLE_MOCK=true expo start --clear",
    "android:mock": "cross-env BLE_MOCK=true expo start --android --clear",
    "ios:mock": "cross-env BLE_MOCK=true expo start --ios --clear",
    "ble:start": "ble-faker --port 58083",
    "ble:stop": "ble-faker stop",
    "test:e2e": "maestro test .maestro/",
    "test:unit": "jest",
    "test": "conc -k -s first -n BLE,JEST -c magenta,cyan \"ble-faker --port 58083\" \"jest\""
  },
  "dependencies": {
    "expo": "~55.0.8",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.4",
    "react-native": "0.83.2",
    "react-native-ble-plx": "^3.5.1",
    "react-native-safe-area-context": "^5.7.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.0.0",
    "@types/react": "~19.2.2",
    "ble-faker": "^1.1.3",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "jest-expo": "~55.0.11",
    "react-test-renderer": "19.2.4",
    "typescript": "~5.9.2"
  },
  "private": true
}
